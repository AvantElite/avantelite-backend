# ── Base de datos (Railway Postgres plugin) ───────────────────────────────────
# Recomendado: usa DATABASE_URL (Railway la inyecta automáticamente con el plugin de Postgres).
# Si no, define DB_HOST/DB_PORT/DB_USER/DB_PASS/DB_NAME por separado.
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=
# PGSSL=disable  # descomentar para deshabilitar SSL en local

# ── Servidor ───────────────────────────────────────────────────────────────────
# Railway inyecta PORT automáticamente; no es necesario definirlo manualmente.
PORT=3000
NODE_ENV=production

# ── CORS ───────────────────────────────────────────────────────────────────────
# Dominios del frontend separados por coma (sin barra final).
# Ejemplo: https://avantservice.es,https://www.avantservice.es
ALLOWED_ORIGINS=https://avantservice-frontend-avantelitepracticas-4283s-projects.vercel.app

# ── URL pública del portal de clientes ────────────────────────────────────────
PORTAL_URL=https://avantservice-frontend-avantelitepracticas-4283s-projects.vercel.app/portal.html

# ── Email SMTP ─────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=AvantService

# ── Cloudinary (almacenamiento de archivos) ────────────────────────────────────
# Formato: cloudinary://api_key:api_secret@cloud_name
# Consíguelo en: console.cloudinary.com → Settings → API Keys
CLOUDINARY_URL=

# ── API Keys de IA ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Analíticas ─────────────────────────────────────────────────────────────────
# Días de retención (0 = sin límite)
ANALYTICS_RETENTION_DAYS=90
