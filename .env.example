# Base de datos
DB_HOST=localhost
DB_USER=avantservice_user
DB_PASS=
DB_NAME=backendavant

# Email SMTP
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=AvantService

# API Keys de IA
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Servidor
PORT=3000
# En producción cambia a "production" para activar cookies Secure y HSTS real
NODE_ENV=development

# Días de retención de datos de analíticas (0 = sin límite)
ANALYTICS_RETENTION_DAYS=90

# Directorio y retención de backups (usado por scripts/backup-db.sh)
BACKUP_DIR=/var/backups/avantservice
BACKUP_KEEP_DAYS=14

# CORS — orígenes permitidos separados por coma
# Desarrollo:  http://localhost:5173,http://127.0.0.1:5500
# Producción:  https://avantservice.es
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5500

# URL pública del portal de clientes (sin barra final)
# Desarrollo:  http://localhost/backendavant/portal.html
# Producción:  https://avantservice.es/portal.html
PORTAL_URL=http://localhost/backendavant/portal.html
