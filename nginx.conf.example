# ── Redirige todo HTTP → HTTPS ────────────────────────────────────────────────
server {
    listen 80;
    server_name tudominio.es www.tudominio.es;
    return 301 https://$host$request_uri;
}

# ── HTTPS principal ───────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name tudominio.es www.tudominio.es;

    # Certificados (Let's Encrypt con certbot)
    ssl_certificate     /etc/letsencrypt/live/tudominio.es/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tudominio.es/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache   shared:SSL:10m;

    # Frontend (archivos estáticos del build de Vite)
    root /var/www/avantpanel/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # API → proxy al backend Node.js (puerto 3000)
    location /api/ {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # Formulario de contacto y rutas raíz del backend
    location ~ ^/(contacto|api/diy) {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Portal de clientes
    location /portal.html {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # Archivos subidos — solo accesibles con sesión válida
    # Opción A (simple): bloquear acceso directo y servir desde Node
    location /uploads/ {
        deny all;
    }
    # Opción B: si quieres servir estáticamente, protege con autenticación básica:
    # location /uploads/ {
    #     alias /var/www/backendavant/uploads/;
    #     auth_basic "Restringido";
    #     auth_basic_user_file /etc/nginx/.htpasswd;
    # }

    # Cabeceras de seguridad adicionales al frontend
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options    nosniff                               always;
    add_header X-Frame-Options           DENY                                  always;
    add_header Referrer-Policy           "strict-origin-when-cross-origin"     always;

    # Logs
    access_log /var/log/nginx/avantservice_access.log;
    error_log  /var/log/nginx/avantservice_error.log;
}
